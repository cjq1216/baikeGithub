# baike dev 默认配置 — clone 后直接 python run.py 即可
# 假设:本机 MySQL 5.7+/8.0 已起,user=root,空密码,库 baike 已建
# 改值后无需重启 shell,改 .env.dev 重启 python run.py 即可

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=baike

# 可选:取消注释并填值启用
# FLASK_SECRET=   # dev 不传,自动走 instance/.flask_secret 持久化
# FLASK_DEBUG=1   # 启 Flask debug 模式
